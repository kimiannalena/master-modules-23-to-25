      <textAnnotation id="sid-ABD3D23F-F000-4E7D-BF06-8537F6D11598" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Pflichtfelder sind Kunden- und Kredit-informationen. Versicherungs-informationen sind optional</text>
      </textAnnotation>
      <textAnnotation id="sid-35B744CC-FBA4-4C86-9FDA-FD3432E30529" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Förderfähige Anträge müssen niedriges Risiko ausweisen und Kreditsumme muss unter Marktwert der Immobilie sein</text>
      </textAnnotation>
      <textAnnotation id="sid-C90846CE-53E2-4D3D-A3F8-3835920AB846" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Kunde muss alle Kreditvereinbarungsklauseln akzeptieren und dem Tilgungsplan zustimmen</text>
      </textAnnotation>
   </process>
